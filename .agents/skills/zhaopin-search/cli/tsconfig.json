{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
   "lib": ["ES2022"],
   "types": ["bun-types"],
   "strict": true,
   "noEmit": true,
   "skipLibCheck": true,
   "noUnusedLocals": false
  },
   "include": ["src/**/*.ts"],
   "exclude": ["tests"]
}
